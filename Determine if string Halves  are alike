class Solution {
    public boolean halvesAreAlike(String s) {
        int n = s.length();
        // Define all vowels in a single string for easy lookup
        String vowels = "aeiouAEIOU";
        
        int countA = 0;
        int countB = 0;
        
        // We can iterate through both halves in a single loop
        for (int i = 0; i < n / 2; i++) {
            // Check first half (left side)
            if (vowels.indexOf(s.charAt(i)) != -1) {
                countA++;
            }
            // Check second half (right side)
            if (vowels.indexOf(s.charAt(i + n / 2)) != -1) {
                countB++;
            }
        }
        
        return countA == countB;
    }
}
