import java.util.*;

public class Solution {
    /**
     * Compares two triplets and returns the score array.
     * @param a Alice's ratings
     * @param b Bob's ratings
     * @return List of 2 integers: [Alice Score, Bob Score]
     */
    public static List<Integer> compareTriplets(List<Integer> a, List<Integer> b) {
        int aliceScore = 0;
        int bobScore = 0;

        // Iterate through the three categories
        for (int i = 0; i < 3; i++) {
            if (a.get(i) > b.get(i)) {
                aliceScore++;
            } else if (a.get(i) < b.get(i)) {
                bobScore++;
            }
            // No else needed for a.get(i) == b.get(i) as points aren't awarded
        }

        // Return scores as a list
        return Arrays.asList(aliceScore, bobScore);
    }
}
